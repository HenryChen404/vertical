# Composio OAuth Integration
# Get your API key from https://dashboard.composio.dev
COMPOSIO_API_KEY=

# Auth Config IDs — create these in Composio dashboard for each provider
COMPOSIO_GOOGLE_CALENDAR_AUTH_CONFIG_ID=
COMPOSIO_OUTLOOK_CALENDAR_AUTH_CONFIG_ID=
COMPOSIO_SALESFORCE_AUTH_CONFIG_ID=

# Webhook signature verification (optional, recommended for production)
# Get this from Composio dashboard webhook settings
COMPOSIO_WEBHOOK_SECRET=

# CRM Update Workflow
GEMINI_API_KEY=              # Gemini 3 Flash (extraction + review)
ELEVENLABS_API_KEY=          # ElevenLabs Scribe v2 (local recording transcription)
SUPABASE_DB_URI=             # LangGraph checkpointer (postgres://user:pass@host:port/db)

# PLAUD OAuth
PLAUD_CLIENT_ID=
PLAUD_CLIENT_SECRET=
SESSION_SECRET=              # Random secret for signing session JWTs
